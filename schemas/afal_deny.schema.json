{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vcav.io/schemas/afal_deny.schema.json",
  "title": "AFAL DENY Message",
  "description": "DENY message for AFAL protocol (Binding Spec v1, Section 3.3). Constant shape: exactly 6 fields.",
  "type": "object",
  "required": [
    "admission_version", "proposal_id", "outcome", "deny_code", "expires_at", "signature"
  ],
  "additionalProperties": false,
  "properties": {
    "admission_version": { "type": "string", "const": "1" },
    "proposal_id": { "type": "string" },
    "outcome": { "type": "string", "const": "DENY" },
    "deny_code": { "type": "string", "minLength": 1 },
    "expires_at": { "type": "string", "format": "date-time" },
    "signature": { "type": "string", "pattern": "^[0-9a-f]{128}$" }
  }
}
