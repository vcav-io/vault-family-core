{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vcav.io/schemas/receipt.v2.schema.json",
  "title": "Receipt V2",
  "description": "Current VCAV receipt schema matching receipt-core ReceiptV2 (v2.1.0).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_schema_version",
    "receipt_canonicalization",
    "receipt_id",
    "session_id",
    "issued_at",
    "assurance_level",
    "operator",
    "commitments",
    "claims",
    "signature"
  ],
  "properties": {
    "receipt_schema_version": {
      "type": "string",
      "const": "2.1.0"
    },
    "receipt_canonicalization": {
      "type": "string",
      "const": "JCS_V1"
    },
    "receipt_id": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "assurance_level": {
      "type": "string",
      "enum": [
        "SELF_ASSERTED",
        "OPERATOR_AUDITED",
        "PROVIDER_ATTESTED",
        "TEE_ATTESTED"
      ]
    },
    "operator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operator_id",
        "operator_key_fingerprint"
      ],
      "properties": {
        "operator_id": {
          "type": "string",
          "minLength": 1
        },
        "operator_key_fingerprint": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "operator_key_discovery": {
          "type": "string"
        }
      }
    },
    "commitments": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_hash",
        "schema_hash",
        "output_hash",
        "input_commitments",
        "assembled_prompt_hash",
        "prompt_assembly_version"
      ],
      "properties": {
        "contract_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "schema_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "output_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "input_commitments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "participant_id",
              "input_hash",
              "hash_alg",
              "canonicalization"
            ],
            "properties": {
              "participant_id": {
                "type": "string",
                "minLength": 1
              },
              "input_hash": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "hash_alg": {
                "type": "string",
                "enum": [
                  "SHA-256",
                  "SHA-384",
                  "SHA-512"
                ]
              },
              "canonicalization": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "assembled_prompt_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "prompt_assembly_version": {
          "type": "string",
          "minLength": 1
        },
        "output": {},
        "prompt_template_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "effective_config_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "preflight_bundle": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "policy_hash",
            "prompt_template_hash",
            "model_profile_hash",
            "schema_hash",
            "enforcement_parameters"
          ],
          "properties": {
            "policy_hash": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "prompt_template_hash": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "model_profile_hash": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "schema_hash": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "enforcement_parameters": {}
          }
        },
        "output_retrieval_uri": {
          "type": "string"
        },
        "output_media_type": {
          "type": "string"
        },
        "preflight_bundle_uri": {
          "type": "string"
        },
        "rejected_output_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "initiator_submission_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "responder_submission_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "claims": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model_identity_asserted": {
          "type": "string"
        },
        "model_identity_attested": {
          "type": "string"
        },
        "model_profile_hash_asserted": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "runtime_hash_asserted": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "runtime_hash_attested": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "budget_enforcement_mode": {
          "type": "string",
          "enum": [
            "enforced",
            "advisory",
            "disabled"
          ]
        },
        "provider_latency_ms": {
          "type": "integer",
          "minimum": 0
        },
        "token_usage": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "prompt_tokens",
            "completion_tokens",
            "total_tokens"
          ],
          "properties": {
            "prompt_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "completion_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "total_tokens": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "relay_software_version": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "success",
            "rejected",
            "aborted",
            "error"
          ]
        },
        "signal_class": {
          "type": "string"
        },
        "execution_lane": {
          "type": "string",
          "enum": [
            "standard",
            "tee"
          ]
        },
        "channel_capacity_bits_upper_bound": {
          "type": "integer",
          "minimum": 0
        },
        "channel_capacity_measurement_version": {
          "type": "string"
        },
        "entropy_budget_bits": {
          "type": "integer",
          "minimum": 0
        },
        "schema_entropy_ceiling_bits": {
          "type": "integer",
          "minimum": 0
        },
        "budget_usage": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "bits_used_before",
            "bits_used_after",
            "budget_limit"
          ],
          "properties": {
            "bits_used_before": {
              "type": "integer",
              "minimum": 0
            },
            "bits_used_after": {
              "type": "integer",
              "minimum": 0
            },
            "budget_limit": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "provider_attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_attestation_blob",
        "provider_attestation_type",
        "provider_key_id"
      ],
      "properties": {
        "provider_attestation_blob": {
          "type": "string"
        },
        "provider_attestation_type": {
          "type": "string"
        },
        "provider_key_id": {
          "type": "string"
        },
        "provider_key_discovery_uri": {
          "type": "string"
        }
      }
    },
    "tee_attestation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tee_type": {
          "type": "string",
          "enum": [
            "SGX",
            "TDX",
            "SEV-SNP",
            "TrustZone",
            "Simulated"
          ]
        },
        "measurement": {
          "type": "string"
        },
        "quote": {
          "type": "string"
        },
        "attestation_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "receipt_signing_pubkey_hex": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "transcript_hash_hex": {
          "type": "string",
          "pattern": "^[a-f0-9]{128}$"
        },
        "user_data_hex": {
          "type": "string",
          "pattern": "^[a-f0-9]{128}$"
        },
        "snp_vcek_cert": {
          "type": "string"
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alg",
        "value"
      ],
      "properties": {
        "alg": {
          "type": "string",
          "enum": [
            "Ed25519",
            "ES256",
            "ES384"
          ]
        },
        "value": {
          "type": "string",
          "minLength": 1
        },
        "signed_fields": {
          "type": "string"
        }
      }
    }
  }
}
