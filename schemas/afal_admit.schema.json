{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vcav.io/schemas/afal_admit.schema.json",
  "title": "AFAL ADMIT Message",
  "description": "ADMIT message for AFAL protocol (Binding Spec v1, Section 3.2)",
  "type": "object",
  "required": [
    "admission_version", "proposal_id", "outcome", "admit_token_id",
    "admission_tier", "expires_at", "signature"
  ],
  "additionalProperties": false,
  "properties": {
    "admission_version": { "type": "string", "const": "1" },
    "proposal_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "outcome": { "type": "string", "const": "ADMIT" },
    "admit_token_id": { "type": "string", "minLength": 1, "maxLength": 64 },
    "admission_tier": {
      "type": "string",
      "enum": ["TRUSTED", "DEFAULT", "LOW_TRUST"]
    },
    "expires_at": { "type": "string", "format": "date-time" },
    "signature": { "type": "string", "pattern": "^[0-9a-f]{128}$" }
  }
}
