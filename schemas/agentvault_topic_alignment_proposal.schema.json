{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentVaultTopicAlignmentProposal",
  "type": "object",
  "additionalProperties": false,
  "required": ["alignment_id", "acceptable_topic_codes"],
  "properties": {
    "alignment_id": { "type": "string", "minLength": 1 },
    "acceptable_topic_codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_]+$"
      }
    },
    "expected_counterparty": { "type": "string", "minLength": 1 }
  }
}
